# Plantilla: Harness State JSON

> Fase: Features (transversal)
> Artefacto: `.harness-state.json`

---

{
  "project": "{Nombre del Proyecto}",
  "createdAt": "{ISO8601}",
  "updatedAt": "{ISO8601}",
  "humanInTheLoop": true,
  "inception": {
    "status": "pending",
    "approved": false,
    "phases": {
      "context":      { "status": "pending", "startedAt": null, "completedAt": null },
      "discovery":    { "status": "pending", "startedAt": null, "completedAt": null },
      "ddd":          { "status": "pending", "startedAt": null, "completedAt": null },
      "architecture": { "status": "pending", "startedAt": null, "completedAt": null },
      "scaffold":     { "status": "pending", "startedAt": null, "completedAt": null },
      "environments": { "status": "pending", "startedAt": null, "completedAt": null }
    }
  },
  "features": []
}

---

